# Variables d'environnement requises — copier vers .env puis renseigner les vraies valeurs.
# Le fichier .env réel ne doit jamais être committé (déjà dans .gitignore).

# Base de données MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=upcycleconnect

# DSN utilisé par l'API Go (mêmes identifiants que MySQL ci-dessus)
DB_DSN=root:change-me@tcp(mysql:3306)/upcycleconnect?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci&loc=Local

# Secret de signature des JWT — chaîne longue et aléatoire (32+ caractères)
JWT_SECRET=change-me-to-a-long-random-string

# URL interne de l'API, consommée par le frontend PHP
API_BASE_URL=http://api:8080/api

# URL publique de l'application (origine CORS autorisée + URLs de retour Stripe)
APP_URL=https://95.216.77.54.nip.io

# Clé secrète Stripe (test : sk_test_... / production : sk_live_...)
STRIPE_SECRET_KEY=sk_test_xxx

# OneSignal (notifications push) — laisser vide pour désactiver le push (l'app
# fonctionne sans). App ID = public (injecté côté navigateur) ; REST API Key =
# SECRET (utilisée seulement côté API Go, jamais exposée au navigateur).
# Récupérer les deux dans OneSignal > Settings > Keys & IDs.
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

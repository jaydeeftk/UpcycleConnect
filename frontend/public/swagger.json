    "/auth/login": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Connexion utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "mot_de_passe": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token JWT retourné" },
          "401": { "description": "Identifiants incorrects" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Authentification"],
        "summary": "Inscription utilisateur",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nom": { "type": "string" },
                  "prenom": { "type": "string" },
                  "email": { "type": "string" },
                  "mot_de_passe": { "type": "string" },
                  "role": { "type": "string", "enum": ["particulier", "professionnel"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Compte créé" },
          "409": { "description": "Email déjà utilisé" }
        }
      }
    },

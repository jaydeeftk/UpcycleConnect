# =============================================================
#  Pile RGPD isolée — variables d'environnement
#  Copier ce fichier en .env DANS infra/rgpd/ puis renseigner des
#  valeurs fortes. Ne JAMAIS committer le .env réel.
# =============================================================

# Mot de passe de l'utilisateur applicatif de la base RGPD.
RGPD_DB_PASSWORD=change-moi-mot-de-passe-rgpd-fort

# Mot de passe root de la base RGPD (administration uniquement).
RGPD_DB_ROOT_PASSWORD=change-moi-mot-de-passe-root-fort

# Jeton porteur exigé par l'application (en-tête Authorization: Bearer).
# En production, il est porté/propagé par le bastion Teleport ; générer
# une valeur aléatoire longue, p. ex. : openssl rand -hex 32
RGPD_API_TOKEN=change-moi-jeton-aleatoire-64-hex
